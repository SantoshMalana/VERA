# Example .env — copy to .env and fill in your keys
# Gemini 2.5 Flash keys (29x, comma-separated) — fallback, reply, self-eval
GEMINI_API_KEY=your_key_1,your_key_2,your_key_3
GEMINI_MODEL=gemini-2.5-flash

# Gemini 3 Flash keys (10x, comma-separated) — primary composer
GEMINI3_API_KEY=your_g3_key_1,your_g3_key_2,your_g3_key_3
GEMINI3_MODEL=gemini-2.0-flash

# Self-evaluation toggle
VERA_SELF_EVAL=true
